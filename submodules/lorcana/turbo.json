{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".svelte-kit/output/**", ".svelte-kit/cloudflare/**"],
      "inputs": [
        "src/**",
        "static/**",
        "public/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.*.json",
        "svelte.config.js",
        "vite.config.ts"
      ],
      "env": ["PLATFORM", "NODE_ENV"]
    },
    "@tcg/lorcana-engine#build": {
      "dependsOn": ["^build", "check-types"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsconfig.*.json"],
      "env": ["PLATFORM", "NODE_ENV"]
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "outputs": [],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.svelte", "tsconfig.json", "tsconfig.*.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "i18n:compile": {
      "outputs": ["src/lib/paraglide/**", "src/i18n/paraglide/**"]
    },
    "lint": {
      "outputs": []
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["AGENT"]
    },
    "ci-check": {
      "cache": true,
      "outputs": [],
      "outputLogs": "errors-only",
      "env": ["CI", "NODE_ENV", "AGENT"],
      "inputs": [
        "package.json",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "tsconfig.*.json",
        "*.config.*",
        "packages/**",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.vite/**",
        "!**/.svelte-kit/**",
        "!**/coverage/**",
        "!**/dist/**",
        "!**/build/**",
        "!**/*.tsbuildinfo"
      ]
    },
    "ci-check-full": {
      "cache": true,
      "outputs": [
        "packages/**/dist/**",
        "packages/**/build/**",
        "packages/**/.svelte-kit/output/**",
        "packages/**/.svelte-kit/cloudflare/**"
      ],
      "outputLogs": "errors-only",
      "env": ["CI", "NODE_ENV", "AGENT"],
      "inputs": [
        "package.json",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "tsconfig.*.json",
        "*.config.*",
        "packages/**",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.vite/**",
        "!**/.svelte-kit/**",
        "!**/coverage/**",
        "!**/dist/**",
        "!**/build/**",
        "!**/*.tsbuildinfo"
      ]
    }
  }
}
