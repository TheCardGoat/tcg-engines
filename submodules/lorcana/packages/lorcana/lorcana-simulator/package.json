{
  "name": "@tcg/lorcana-simulator",
  "version": "0.0.1",
  "keywords": [
    "svelte"
  ],
  "files": [
    "src/"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/lib/index.ts",
  "module": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "svelte": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "import": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    }
  },
  "scripts": {
    "dev": "vp dev",
    "dev:calm": "HOT_UPDATE_DELAY_MS=1200 vp dev",
    "build": "vp build && pnpm run prepack",
    "build:node": "PLATFORM=node vp build",
    "preview": "vp preview",
    "start": "node build/index.js",
    "format": "bun x oxfmt --no-error-on-unmatched-pattern --write 'src/**/*.{js,jsx,ts,tsx,json,jsonc,json5,css,scss,less,html,md,mdx,graphql,yml,yaml,toml}'",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "bun run i18n:compile && svelte-kit sync && svelte-package && publint",
    "i18n:verify": "pnpm run i18n:compile && pnpm run i18n:check",
    "i18n:compile": "vpx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "i18n:check": "node ./scripts/check-i18n-catalog.ts && bun run ./scripts/check-localized-copy.ts && bun run ./scripts/check-translation-keys.ts",
    "check-types": "pnpm run i18n:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:data-layer": "bun run ./scripts/check-no-raw-fetch.ts",
    "check": "bun run check-types",
    "check:watch": "pnpm run i18n:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "test:e2e:dev": "bunx tsx ./node_modules/.bin/playwright test",
    "test:e2e:ui": "bunx tsx ./node_modules/.bin/playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:report": "playwright show-report",
    "test:simulator-jsdom": "vp test run --environment jsdom src/testing/*.vitest.test.ts vitest/*.vitest.test.ts",
    "test:rules": "AGENT=1 bun test --silent src/testing/rules",
    "test:unit": "pnpm run i18n:compile && svelte-kit sync && AGENT=1 bun test --silent src/lib",
    "test:strategy": "AGENT=1 bun test --silent src/testing/ai-strategy/*.test.ts",
    "test:strategy:quick": "RUN_STRATEGY_LAB=1 STRATEGY_PRESET=quick AGENT=1 bun test --silent src/testing/ai-strategy/*.test.ts",
    "test:strategy:candidate": "RUN_STRATEGY_LAB=1 STRATEGY_PRESET=candidate AGENT=1 bun test --silent src/testing/ai-strategy/*.test.ts",
    "test:strategy:promotion": "RUN_STRATEGY_LAB=1 STRATEGY_PRESET=promotion AGENT=1 bun test --silent src/testing/ai-strategy/*.test.ts",
    "test:strategy:lab": "RUN_STRATEGY_LAB=1 AGENT=1 bun test --silent src/testing/ai-strategy/*.test.ts",
    "test:strategy:quick-replay": "RUN_STRATEGY_QUICK_REPLAY=1 AGENT=1 bun test --silent src/testing/ai-strategy/simulate-game.test.ts",
    "test:strategy:replay": "RUN_STRATEGY_REPLAY=1 AGENT=1 bun test --silent src/testing/ai-strategy/simulate-game.test.ts",
    "test:strategy:benchmark": "RUN_STRATEGY_BENCHMARK=1 STRATEGY_GAME_COUNT=100 AGENT=1 bun test --silent src/testing/ai-strategy/*.test.ts",
    "test": "bun run test:rules && bun run test:unit"
  },
  "dependencies": {
    "@better-auth/infra": "catalog:",
    "@better-auth/stripe": "^1.6.9",
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/svelte": "^0.3.2",
    "@formkit/auto-animate": "^0.9.0",
    "@iconify/svelte": "^5.0.2",
    "@logtape/logtape": "^2.0.4",
    "@logtape/pretty": "^2.0.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/context-zone": "^2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-document-load": "^0.63.0",
    "@opentelemetry/instrumentation-fetch": "^0.218.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.62.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tanstack/svelte-hotkeys": "^0.5.1",
    "@tanstack/svelte-query": "^6.1.16",
    "@tanstack/svelte-table": "^8.21.3",
    "@tanstack/svelte-virtual": "^3.13.22",
    "@tcg/lorcana-cards": "workspace:*",
    "@tcg/lorcana-engine": "workspace:*",
    "@tcg/lorcana-interaction": "workspace:*",
    "@tcg/lorcana-types": "workspace:*",
    "@tcg/shared": "workspace:*",
    "@unpic/svelte": "^1.0.0",
    "add": "^2.0.6",
    "better-auth": "catalog:",
    "bits-ui": "^2.16.3",
    "button-group": "^0.0.4",
    "context-menu": "^2.0.0",
    "fflate": "^0.8.2",
    "howler": "^2.2.4",
    "install": "^0.13.0",
    "kbd": "^0.1.0",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.0",
    "mutative": "^1.1.0",
    "prosekit": "^0.18.4",
    "runed": "^0.28.0",
    "svelte-confetti": "^2.3.2",
    "svelte-json-tree": "^2.2.0",
    "svelte-sonner": "^1.0.7",
    "tsx": "^4.21.0",
    "web-vitals": "^5.2.0",
    "x": "^0.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.10.0",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@playwright/test": "^1.58.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "4.1.18",
    "@tcg/game-page-contract": "link:../../../../agnostic-simulator/packages/game-page-contract",
    "@tcg/simulator-testing": "link:../../../../agnostic-simulator/packages/simulator-testing",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.0.18",
    "clsx": "^2.1.1",
    "daisyui": "5.5.19",
    "jsdom": "^29.0.0",
    "layerchart": "2.0.0-next.48",
    "playwright": "^1.58.2",
    "publint": "^0.3.17",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.10",
    "svelte-check": "^4.3.6",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
