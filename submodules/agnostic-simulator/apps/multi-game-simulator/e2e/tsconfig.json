{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@tcg/simulator-testing/playwright": ["../../../packages/simulator-testing/src/playwright.ts"]
    }
  },
  "include": ["./**/*.ts", "../playwright.config.ts"]
}
