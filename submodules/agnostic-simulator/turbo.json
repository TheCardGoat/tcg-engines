{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "outputs": ["dist/**", "build/**", ".svelte-kit/output/**"]
    },
    "check": {
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "check-types": {
      "cache": true,
      "outputs": [],
      "outputLogs": "errors-only",
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.svelte", "tsconfig.json", "tsconfig.*.json"]
    },
    "test": {
      "outputs": [],
      "outputLogs": "errors-only",
      "env": ["AGENT"]
    },
    "ci-check": {
      "cache": true,
      "outputs": [],
      "outputLogs": "errors-only",
      "env": ["CI", "NODE_ENV", "AGENT"],
      "inputs": [
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "vite.config.ts",
        "turbo.json",
        "tsconfig.json",
        "tsconfig.*.json",
        "apps/**",
        "packages/**",
        "tools/**",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.vite/**",
        "!**/.svelte-kit/**",
        "!**/coverage/**",
        "!**/dist/**",
        "!**/build/**",
        "!**/*.tsbuildinfo"
      ]
    },
    "ci-check-full": {
      "cache": true,
      "outputs": [
        "dist/**",
        "build/**",
        "apps/**/dist/**",
        "apps/**/build/**",
        "packages/**/dist/**"
      ],
      "outputLogs": "errors-only",
      "env": ["CI", "NODE_ENV", "AGENT"],
      "inputs": [
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "vite.config.ts",
        "turbo.json",
        "tsconfig.json",
        "tsconfig.*.json",
        "apps/**",
        "packages/**",
        "tools/**",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.vite/**",
        "!**/.svelte-kit/**",
        "!**/coverage/**",
        "!**/dist/**",
        "!**/build/**",
        "!**/*.tsbuildinfo"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "full"
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "outputLogs": "errors-only"
    }
  }
}
