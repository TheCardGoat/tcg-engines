{
  "name": "@tcg/cyberpunk-server-adapter",
  "version": "0.1.0",
  "private": true,
  "description": "Server-side GameAdapter implementation for Cyberpunk — wires the Cyberpunk LocalEngine into the @tcg/shared/game-adapter contract.",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./interaction-protocol": "./src/interaction-protocol.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "bun x oxfmt --write ./src",
    "lint": "bun x oxlint --fix ./src",
    "check-types": "tsc --noEmit",
    "test": "vp test run --passWithNoTests"
  },
  "dependencies": {
    "@tcg/cyberpunk-cards": "link:../../../../cyberpunk/packages/cards",
    "@tcg/cyberpunk-engine": "link:../../../../cyberpunk/packages/engine",
    "@tcg/cyberpunk-types": "link:../../../../cyberpunk/packages/types",
    "@tcg/protocol": "link:../../protocol",
    "@tcg/shared": "link:../../shared"
  },
  "devDependencies": {
    "@tcg/typescript-config": "link:../../typescript-config",
    "@types/node": "^22.13.4"
  }
}
