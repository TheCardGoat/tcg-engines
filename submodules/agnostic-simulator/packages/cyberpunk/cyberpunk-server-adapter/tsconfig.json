{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"],
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@tcg/cyberpunk-cards": ["../../../../cyberpunk/packages/cards/src/index.ts"],
      "@tcg/cyberpunk-engine": ["../../../../cyberpunk/packages/engine/src/index.ts"],
      "@tcg/cyberpunk-types": ["../../../../cyberpunk/packages/types/src/index.ts"]
    }
  }
}
