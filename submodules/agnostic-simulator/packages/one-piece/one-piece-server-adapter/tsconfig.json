{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"],
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@tcg/op-cards": ["../../../../one-piece-simulator/packages/cards/src/index.ts"],
      "@tcg/op-engine": ["../../../../one-piece-simulator/packages/engine/src/index.ts"],
      "@tcg/op-types": ["../../../../one-piece-simulator/packages/types/src/index.ts"],
      "@tcg/protocol": ["../../protocol/src/index.ts"],
      "@tcg/shared": ["../../shared/src/index.ts"]
    }
  }
}
