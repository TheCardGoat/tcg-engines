{
  "name": "@tcg/simulator-testing",
  "version": "0.1.0",
  "private": true,
  "description": "Shared DOM drivers and page-object helpers for simulator harness tests.",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./playwright": {
      "types": "./src/playwright.ts",
      "default": "./src/playwright.ts"
    },
    "./testing-library": {
      "types": "./src/testing-library.ts",
      "default": "./src/testing-library.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vp test run --passWithNoTests"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "catalog:"
  },
  "devDependencies": {
    "@tcg/typescript-config": "link:../typescript-config",
    "@types/node": "catalog:",
    "jsdom": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/user-event": "^14.0.0"
  },
  "peerDependenciesMeta": {
    "@testing-library/dom": {
      "optional": true
    },
    "@testing-library/user-event": {
      "optional": true
    }
  }
}
