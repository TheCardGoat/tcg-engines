{
  "name": "@tcg/simulator-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Game-agnostic HTML renderers and styles for TCG simulator harnesses.",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./SimulatorHarness": {
      "types": "./src/SimulatorHarness.tsx",
      "default": "./src/SimulatorHarness.tsx"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./styles/*": {
      "default": "./src/styles/*"
    }
  },
  "scripts": {
    "storybook": "storybook dev --host 127.0.0.1 --port 6006 --no-open",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "format": "vp fmt ./src",
    "lint": "vp lint ./src",
    "test": "bun test"
  },
  "dependencies": {
    "@floating-ui/dom": "catalog:",
    "@tcg/simulator-contract": "link:../simulator-contract",
    "motion": "catalog:"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.4.2",
    "@tailwindcss/vite": "4.1.18",
    "@tcg/typescript-config": "link:../typescript-config",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "10.4.2",
    "tailwindcss": "4.1.18",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
