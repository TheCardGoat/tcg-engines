{
  "name": "@tcg/gundam-card-parser",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "generate:units": "node --experimental-strip-types scripts/generate-unit-files.ts",
    "generate:pilots": "node --experimental-strip-types scripts/generate-pilot-files.ts",
    "generate:commands": "node --experimental-strip-types scripts/generate-command-files.ts",
    "generate:bases": "node --experimental-strip-types scripts/generate-base-files.ts",
    "generate:resources": "node --experimental-strip-types scripts/generate-resource-files.ts",
    "generate": "vp run generate:units && vp run generate:pilots && vp run generate:commands && vp run generate:bases && vp run generate:resources",
    "export:structured-effects": "node --experimental-strip-types scripts/export-structured-effects.ts",
    "scrape:official": "node --experimental-strip-types scripts/scrape-official-to-json.ts",
    "generate:from-scraped": "node --experimental-strip-types scripts/generate-from-scraped.ts",
    "enrich:catalog-metadata": "node --experimental-strip-types scripts/enrich-card-catalog-metadata.ts"
  },
  "dependencies": {
    "@tcg/gundam-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.19"
  }
}
