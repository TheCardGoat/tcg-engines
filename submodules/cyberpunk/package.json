{
  "name": "cyberpunk",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tools/*"
    ],
    "catalog": {
      "@dnd-kit/core": "^6.3.1",
      "@mantine/dropzone": "^9.0.0",
      "@mantine/modals": "^9.0.0",
      "@mantine/notifications": "^9.0.0",
      "@mantine/spotlight": "^9.0.0",
      "@playwright/test": "^1.59.1",
      "@tabler/icons-react": "^3.41.1",
      "@types/node": "^24",
      "cheerio": "^1.2.0",
      "mutative": "^1.3.0",
      "typescript": "^5",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.21",
      "vite-plus": "0.1.21",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.21"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "cd ../agnostic-simulator/apps/multi-game-simulator && VITE_BASE_URL=/cyberpunk/simulator/ vp dev",
    "ci-check": "vp run ci:check",
    "ci-check-full": "vp run ci:full",
    "prepare": "node -e \"process.exit(process.env.CI?0:1)\" || vp config",
    "build": "bunx turbo run build"
  },
  "devDependencies": {
    "bun-types": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "0.1.21"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
